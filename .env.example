API_BASE=http://localhost:11434
#LLM_TIER=free     if using Groq + OpenRouter free keys
#LLM_TIER=paid     if using Anthropic/OpenAI/Gemini key
#LLM_TIER=local    if running Ollama locally
LLM_TIER=
#if using any paid keys enter one of the following
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
USE_CLOUD=true
#ollama model (if you want to us eollama enter the model name)
MODEL=
#if using free tier keys use atleast two free tier providers
GROQ_API_KEY=
OPENROUTER_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=openai/gpt-4o-mini
#get from github
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH="secrets/PRhelp.pem"
GITHUB_INSTALLATION_ID=

